+
+/* Platform profile support using EC_ADDR_MANUAL_FAN_CTRL (0x0751) */
+
+#define FAN_CTRL_PROFILE_MASK	(FAN_MODE_HIGH | FAN_MODE_USER | FAN_MODE_TURBO)
+#define FAN_CTRL_QUIET		(FAN_MODE_HIGH | FAN_MODE_USER)	/* 0xa0 */
+#define FAN_CTRL_BALANCED	0				/* 0x00 */
+#define FAN_CTRL_PERFORMANCE	FAN_MODE_TURBO			/* 0x10 */
+
+static int uniwill_platform_profile_probe(void *drvdata, unsigned long *choices)
+{
+	(void)drvdata;
+
+	set_bit(PLATFORM_PROFILE_QUIET, choices);
+	set_bit(PLATFORM_PROFILE_BALANCED, choices);
+	set_bit(PLATFORM_PROFILE_PERFORMANCE, choices);
+
+	return 0;
+}
+
+static int uniwill_platform_profile_get(struct device *dev,
+					enum platform_profile_option *profile)
+{
+	struct uniwill_data *data = dev_get_drvdata(dev);
+	unsigned int value;
+	int ret;
+
+	ret = regmap_read(data->regmap, EC_ADDR_MANUAL_FAN_CTRL, &value);
+	if (ret < 0)
+		return ret;
+
+	switch (value & FAN_CTRL_PROFILE_MASK) {
+	case FAN_CTRL_QUIET:
+		*profile = PLATFORM_PROFILE_QUIET;
+		break;
+	case FAN_CTRL_PERFORMANCE:
+		*profile = PLATFORM_PROFILE_PERFORMANCE;
+		break;
+	default:
+		*profile = PLATFORM_PROFILE_BALANCED;
+		break;
+	}
+
+	return 0;
+}
+
+static int uniwill_platform_profile_set(struct device *dev,
+					enum platform_profile_option profile)
+{
+	struct uniwill_data *data = dev_get_drvdata(dev);
+	unsigned int value;
+
+	switch (profile) {
+	case PLATFORM_PROFILE_QUIET:
+		value = FAN_CTRL_QUIET;
+		break;
+	case PLATFORM_PROFILE_BALANCED:
+		value = FAN_CTRL_BALANCED;
+		break;
+	case PLATFORM_PROFILE_PERFORMANCE:
+		value = FAN_CTRL_PERFORMANCE;
+		break;
+	default:
+		return -EOPNOTSUPP;
+	}
+
+	return regmap_update_bits(data->regmap, EC_ADDR_MANUAL_FAN_CTRL,
+				 FAN_CTRL_PROFILE_MASK, value);
 }
 
+static const struct platform_profile_ops uniwill_platform_profile_ops = {
+	.probe = uniwill_platform_profile_probe,
+	.profile_get = uniwill_platform_profile_get,
+	.profile_set = uniwill_platform_profile_set,
+};
+
+static int uniwill_platform_profile_init(struct uniwill_data *data)
+{
+	struct device *profile_dev;
+
+	if (!uniwill_device_supports(data, UNIWILL_FEATURE_PLATFORM_PROFILE))
+		return 0;
+
+	profile_dev = devm_platform_profile_register(data->dev, "uniwill-laptop",
+						     data, &uniwill_platform_profile_ops);
+
+	return IS_ERR(profile_dev) ? PTR_ERR(profile_dev) : 0;
+}
